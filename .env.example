# Copy to .env and fill in:  cp .env.example .env

# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/cis

# Auth (skeleton stub session — B2 replaces with Azure AD / NextAuth)
# generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Observability (B0 uses console span exporter; OTLP backend TBD — D-006)
OTEL_SERVICE_NAME=cis
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
